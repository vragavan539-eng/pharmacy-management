# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pharmacy_ai
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pharmacy_ai

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ── Anthropic AI ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Client URL (CORS) ─────────────────────────────────
CLIENT_URL=http://localhost:3000
